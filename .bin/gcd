#!/bin/bash

findHerdrWorkspace() {
  local name=$1

  herdr workspace list 2>/dev/null |
    jq -r --arg name "$name" '.result.workspaces[] | select(.label == $name) | .workspace_id' |
    head -n 1
}

openHerdrWorkspace() {
  local name=$1
  local dir=$2
  local workspace_id

  workspace_id=$(findHerdrWorkspace "$name")
  if [[ -n "$workspace_id" ]]; then
    herdr workspace focus "$workspace_id"
  else
    herdr workspace create --cwd "$dir" --label "$name" --focus || {
      cd "$dir" || return 1
      exec herdr
    }
  fi

  if [[ -z "${HERDR_ENV:-}" ]]; then
    exec herdr
  fi
}

selectRepo() {
  local repo=$(ghq list | fzf)
  if [[ -n "$repo" ]]; then
    echo "$(ghq root)/$repo"
  fi
}

main() {
  local repo_path=$(selectRepo)

  if [[ -z "$repo_path" ]]; then
    return 1
  fi

  # リポジトリ名（最後の部分）をワークスペース名として使用
  local workspace_name=$(basename "$repo_path")

  openHerdrWorkspace "$workspace_name" "$repo_path"
}

main "$@"
